{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kraken-dual-agent-demo.vercel.app/schemas/dual-trade-receipt.schema.json",
  "title": "DUAL Kraken Trade Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "passport_id",
    "proposal_id",
    "trade_pair",
    "trade_side",
    "notional_usd",
    "policy_hash",
    "execution_mode",
    "execution_digest",
    "event_id",
    "event_hash",
    "receipt_hash",
    "status",
    "executed_at"
  ],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^tr-[a-f0-9]{12}$" },
    "schema_version": { "type": "string", "const": "dual-kraken-trade-receipt.v1" },
    "passport_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "proposal_id": { "type": "string", "pattern": "^prop-" },
    "trade_pair": { "type": "string", "enum": ["BTCUSD", "ETHUSD", "SOLUSD", "DUALUSD"] },
    "trade_side": { "type": "string", "enum": ["buy", "sell"] },
    "trade_quantity": { "type": "string" },
    "trade_price_usd": { "type": "string" },
    "notional_usd": { "type": "string" },
    "policy_decision": { "type": "string", "enum": ["allow", "needs_approval", "block"] },
    "policy_version": { "type": "string" },
    "policy_hash": { "type": "string" },
    "execution_mode": { "type": "string", "const": "paper" },
    "execution_source": { "type": "string" },
    "execution_digest": { "type": "string" },
    "event_id": { "type": "string", "pattern": "^evt-" },
    "event_hash": { "type": "string" },
    "receipt_hash": { "type": "string" },
    "status": { "type": "string", "enum": ["executed"] },
    "executed_at": { "type": "string", "format": "date-time" },
    "last_event_type": { "type": "string" },
    "last_event_status": { "type": "string" },
    "last_event_hash": { "type": "string" }
  }
}
