# Local server
PORT=4173
HOST=127.0.0.1

# Kraken CLI remains optional. If the `kraken` binary is unavailable, the app uses simulator fallback.

# DUAL persistence mode:
# - local: use local simulator only
# - dual: sync passport/audit lifecycle to DUAL via dual-sdk
DUAL_PERSISTENCE_MODE=local
DUAL_API_URL=https://gateway-48587430648.europe-west6.run.app
DUAL_API_KEY=
DUAL_ORG_ID=
DUAL_AGENT_PASSPORT_TEMPLATE_ID=
DUAL_AGENT_PASSPORT_OBJECT_ID=

# API-key auth supports read verification of the linked passport.
# Event-bus write sync needs email-code bearer auth or a service-account bearer token.
DUAL_AUTH_MODE=api_key
DUAL_WRITE_MODE=read_only
DUAL_SERVICE_ACCOUNT_TOKEN=
