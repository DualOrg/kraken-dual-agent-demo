# Local server
PORT=4173
HOST=127.0.0.1

# Optional local state override. Leave unset to use data/state.json locally
# and /tmp/kraken-dual-agent-state.json on Vercel.
# STATE_PATH=/tmp/kraken-dual-agent-state.json

# Kraken CLI remains optional. If the `kraken` binary is unavailable, the app
# uses Kraken public market data and then simulator-safe paper execution.

# DUAL persistence mode:
# - local: use the local simulator only
# - dual: sync passport/audit lifecycle to DUAL via dual-sdk
DUAL_PERSISTENCE_MODE=local

# DUAL network migration guard. Mainnet mode fails closed until the cutover flag
# is true and DUAL API/Console/Explorer bases are replaced with explicit
# non-testnet endpoints from the new API contract.
DUAL_NETWORK=testnet
KRAKEN_MAINNET_CUTOVER_CONFIRMED=false

DUAL_API_URL=https://api-testnet.dual.network
DUAL_API_KEY=
DUAL_ORG_ID=
DUAL_AGENT_PASSPORT_TEMPLATE_ID=
DUAL_AGENT_PASSPORT_OBJECT_ID=
DUAL_TRADE_RECEIPT_TEMPLATE_ID=

# API-key auth is the normal DUAL-backed path for this demo. Event-bus writes
# need a scoped server-side API key and DUAL_WRITE_MODE=event_bus.
DUAL_AUTH_MODE=api_key
DUAL_WRITE_MODE=read_only
DUAL_EVENTBUS_WRITE_PATH=/ebus/execute

# Public demo writes are disabled in this example for safety. Set true only on
# a deployment intended to create DUAL paper-trade evidence.
DEMO_PUBLIC_DUAL_WRITES=false
DEMO_ENABLE_EMAIL_AUTH=false

# Agent Mandates read gate. This public evaluator is read-only from Kraken:
# it checks the canonical DUAL-backed mandate before paper execution and never
# sends the operator token or performs Agent Mandates writes.
AGENT_MANDATES_URL=https://agent-mandates-dual-demo.vercel.app
# Optional: use the Agent Mandates MCP instead of the direct HTTP evaluator.
# When set, Kraken calls agent_mandates_evaluate_action over MCP.
# AGENT_MANDATES_MCP_URL=https://agent-mandates-dual-demo.vercel.app/mcp
AGENT_MANDATES_GATE_MODE=required
AGENT_MANDATES_OBJECT_ID=6a165a5a0b0bf21f33c111cc
AGENT_MANDATES_AGENT_WALLET=agent-mandates-demo-agent-wallet-001
AGENT_MANDATES_JURISDICTION=AU-NSW
AGENT_MANDATES_AUTHORITY_SCOPE=buyer-agent-commerce
AGENT_MANDATES_TIMEOUT_MS=5000

# Allow browser-based MCP clients from specific origins if needed.
# DEMO_MCP_ALLOWED_ORIGINS=https://example.com,https://another.example.com

# Optional URL overrides. Defaults are suitable for current DUAL testnet routes.
DUAL_CONSOLE_BASE_URL=https://console-testnet.dual.network
DUAL_L3_EXPLORER_BASE_URL=https://explorer-testnet.dual.network
DUAL_L2_EXPLORER_BASE_URL=https://explorer-test-v2.dual.network
DUAL_L1_EXPLORER_BASE_URL=

# Legacy/private fallback auth variables. Leave blank for the public demo.
DUAL_SERVICE_ACCOUNT_AUTH_MODE=api_key
DUAL_SERVICE_ACCOUNT_TOKEN=
DUAL_SERVICE_ACCOUNT_REFRESH_TOKEN=
