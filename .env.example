# Local server
PORT=4173
HOST=127.0.0.1

# Kraken CLI remains optional. If the `kraken` binary is unavailable, the app uses simulator fallback.

# DUAL persistence mode:
# - local: use local simulator only
# - dual: sync passport/audit lifecycle to DUAL via dual-sdk
DUAL_PERSISTENCE_MODE=local
DUAL_API_URL=https://api-testnet.dual.network
DUAL_API_KEY=
DUAL_ORG_ID=
DUAL_AGENT_PASSPORT_TEMPLATE_ID=
DUAL_AGENT_PASSPORT_OBJECT_ID=

# API-key auth supports read verification and event-bus writes when scoped for action creation.
# Email-code bearer auth and service tokens remain supported fallback write modes.
DUAL_AUTH_MODE=api_key
DUAL_WRITE_MODE=event_bus
DUAL_EVENTBUS_WRITE_PATH=/ebus/actions
DUAL_SERVICE_ACCOUNT_AUTH_MODE=api_key
DUAL_SERVICE_ACCOUNT_TOKEN=
DUAL_SERVICE_ACCOUNT_REFRESH_TOKEN=
